{
  "name": "drawui",
  "version": "0.2.0",
  "description": "Framework-free DOM UI primitives and components for ESM applications.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "style": "./styles/core.css",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "src",
    "styles/core.css",
    "styles/icons.css",
    "styles/tokens.css",
    "styles/reset.css",
    "styles/primitives.css",
    "styles/components.css",
    "styles/rules.css",
    "styles/app-host.css",
    "styles/base-components.css",
    "styles/structure.css",
    "styles/components/spinner.css",
    "styles/components/nodes.css",
    "styles/components/hud.css",
    "styles/components/pie-menu.css",
    "styles/components/scheduling.css",
    "styles/components/ag-grid-custom.css",
    "styles/themes",
    "vendor/fonts",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./utils/markdown": "./src/utils/markdown.js",
    "./utils/flexResizer": "./src/utils/flexResizer.js",
    "./overlays/drag": "./src/overlays/drag.js",
    "./workspace/dock": "./src/workspace/dock.js",
    "./vendor/fonts/material-symbols-outlined.css": "./vendor/fonts/material-symbols-outlined.css",
    "./styles/core.css": "./styles/core.css",
    "./styles/icons.css": "./styles/icons.css",
    "./styles/tokens.css": "./styles/tokens.css",
    "./styles/reset.css": "./styles/reset.css",
    "./styles/primitives.css": "./styles/primitives.css",
    "./styles/components.css": "./styles/components.css",
    "./styles/structure.css": "./styles/structure.css",
    "./styles/base-components.css": "./styles/base-components.css",
    "./styles/rules.css": "./styles/rules.css",
    "./styles/app-host.css": "./styles/app-host.css",
    "./styles/components/spinner.css": "./styles/components/spinner.css",
    "./styles/components/nodes.css": "./styles/components/nodes.css",
    "./styles/components/hud.css": "./styles/components/hud.css",
    "./styles/components/pie-menu.css": "./styles/components/pie-menu.css",
    "./styles/components/scheduling.css": "./styles/components/scheduling.css",
    "./styles/components/ag-grid-custom.css": "./styles/components/ag-grid-custom.css",
    "./styles/themes/dark.css": "./styles/themes/dark.css",
    "./styles/themes/light.css": "./styles/themes/light.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:source-check": "node --input-type=module -e \"import './src/index.js'\"",
    "examples": "npm run build && npx --yes serve docs -p 5173",
    "build:catalog": "node ./scripts/generate-min-catalog.mjs",
    "docs:index": "node ./scripts/generate-docs.mjs",
    "docs:api": "typedoc && node ./scripts/enhance-typedoc.mjs",
    "docs": "npm run docs:index && npm run docs:api && npm run build:catalog",
    "check:docs": "npm run docs && git diff --exit-code docs/generated",
    "check:entrypoints": "node ./scripts/check-entrypoints.mjs",
    "check:package-contents": "node ./scripts/check-package-contents.mjs"
  },
  "dependencies": {
    "@highlightjs/cdn-assets": "11.11.1",
    "ag-grid-community": "35.2.1",
    "chart.js": "4.4.7",
    "jsgantt-improved": "2.8.10",
    "showdown": "2.1.0"
  },
  "keywords": [
    "ui",
    "dom",
    "components",
    "drawui"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typedoc": "^0.28.5"
  }
}
